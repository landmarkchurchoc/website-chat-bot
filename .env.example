# ===== Required =====
# Anthropic API key (console.anthropic.com). NEVER commit the real key.
ANTHROPIC_API_KEY=

# ===== Recommended =====
# Crossway ESV API key (free for church use — register at https://api.esv.org/account/)
ESV_API_TOKEN=

# URL of Landmark's care request form, shown when a question needs a real person
# (defaults to the Church Center care form if unset)
CARE_FORM_URL=https://thelandmark.churchcenter.com/people/forms/583406

# ===== Question logging to the "AI Search Questions" Monday board =====
# Personal API token: monday.com avatar menu -> Developers -> My access tokens
MONDAY_API_TOKEN=
# Defaults to the AI Search Questions board (18420369585); override if it moves
MONDAY_BOARD_ID=

# ===== Optional overrides =====
# Comma-separated origins allowed to call the API (defaults to thelandmark.church domains)
ALLOWED_ORIGINS=
# Site to crawl during `npm run ingest`
SITE_URL=https://www.thelandmark.church
